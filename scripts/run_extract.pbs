#!/bin/bash
# PBS job: documents (PDF/PPTX/DOCX/images) -> OCR -> technical term list.
#
# Submit:
#   qsub scripts/run_extract.pbs                          # docs/ -> out/
#   qsub -v DOCS_DIR=mydocs,OUT_DIR=out_run2 scripts/run_extract.pbs
#   qsub -v SKIP_OCR=1 scripts/run_extract.pbs            # text-based PDFs only
#   qsub -v MIN_COUNT=2,MAX_TERMS=100 scripts/run_extract.pbs
#
# Logs: written under logs/ (run `mkdir -p logs` beforehand)
#
# NOTE: adjust resource line (-l) and queue (-q) to match your cluster
#PBS -N term_extract
#PBS -l select=1:ncpus=8:ngpus=1:mem=64gb
#PBS -l walltime=12:00:00
#PBS -j oe
#PBS -o logs/
## Uncomment and edit if your cluster requires an explicit queue
##PBS -q gpu

set -euo pipefail

# Jobs start in $HOME; move to the directory the job was submitted from
cd "${PBS_O_WORKDIR:-$(pwd)}"

DOCS_DIR="${DOCS_DIR:-docs/}"
OUT_DIR="${OUT_DIR:-out}"
SKIP_OCR="${SKIP_OCR:-0}"
MIN_COUNT="${MIN_COUNT:-1}"
MAX_TERMS="${MAX_TERMS:-0}"

# Uncomment if your cluster loads CUDA via modules
# module load cuda/12.1

echo "=== node: $(hostname) / GPU: $(nvidia-smi --query-gpu=name --format=csv,noheader || echo unknown) ==="
echo "=== input: $DOCS_DIR / output: $OUT_DIR ==="

if [ "$SKIP_OCR" = "1" ]; then
    echo "=== STEP 1/2: skipping OCR (SKIP_OCR=1) ==="
    EXTRACT_INPUT="$DOCS_DIR"
else
    echo "=== STEP 1/2: OCR (Qwen3-VL) ==="
    uv run --project gemma_runtime python scripts/ocr_documents.py \
        --docs "$DOCS_DIR" \
        --out-dir "$OUT_DIR/text"
    EXTRACT_INPUT="$OUT_DIR/text"
fi

echo "=== STEP 2/2: term extraction (Gemma 4) ==="
uv run --project gemma_runtime python scripts/extract_terms.py \
    --inputs "$EXTRACT_INPUT" \
    --out "$OUT_DIR/terms.txt" \
    --min-count "$MIN_COUNT" \
    --max-terms "$MAX_TERMS"

echo ""
echo "=== done ==="
echo "term list: $OUT_DIR/terms.txt"
echo "first 20 lines:"
head -n 20 "$OUT_DIR/terms.txt"
