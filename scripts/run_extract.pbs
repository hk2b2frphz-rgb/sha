#!/bin/bash
# 文書 (PDF/PPTX/DOCX/画像) → OCR → 専門用語リスト の PBS ジョブ。
#
# 投入:
#   qsub scripts/run_extract.pbs                          # docs/ -> out/
#   qsub -v DOCS_DIR=mydocs,OUT_DIR=out_run2 scripts/run_extract.pbs
#   qsub -v SKIP_OCR=1 scripts/run_extract.pbs            # テキスト PDF のみ
#   qsub -v MIN_COUNT=2,MAX_TERMS=100 scripts/run_extract.pbs
#
# ログ: logs/ 配下に出る (事前に mkdir -p logs しておく)
#
# ※ 資源指定 (-l) とキュー (-q) はクラスタに合わせて調整すること
#PBS -N term_extract
#PBS -l select=1:ncpus=8:ngpus=1:mem=64gb
#PBS -l walltime=12:00:00
#PBS -j oe
#PBS -o logs/
## キュー指定が必要なクラスタでは下を編集して有効化
##PBS -q gpu

set -euo pipefail

# ジョブはホームで起動されるので、投入時のディレクトリへ移動
cd "${PBS_O_WORKDIR:-$(pwd)}"

DOCS_DIR="${DOCS_DIR:-docs/}"
OUT_DIR="${OUT_DIR:-out}"
SKIP_OCR="${SKIP_OCR:-0}"
MIN_COUNT="${MIN_COUNT:-1}"
MAX_TERMS="${MAX_TERMS:-0}"

# CUDA 等を module で読み込むクラスタでは有効化
# module load cuda/12.1

echo "=== ノード: $(hostname) / GPU: $(nvidia-smi --query-gpu=name --format=csv,noheader || echo 不明) ==="
echo "=== 入力: $DOCS_DIR / 出力: $OUT_DIR ==="

if [ "$SKIP_OCR" = "1" ]; then
    echo "=== STEP 1/2: OCR をスキップ (SKIP_OCR=1) ==="
    EXTRACT_INPUT="$DOCS_DIR"
else
    echo "=== STEP 1/2: OCR (Qwen3-VL) ==="
    uv run --project gemma_runtime python scripts/ocr_documents.py \
        --docs "$DOCS_DIR" \
        --out-dir "$OUT_DIR/text"
    EXTRACT_INPUT="$OUT_DIR/text"
fi

echo "=== STEP 2/2: 専門用語抽出 (Gemma 4) ==="
uv run --project gemma_runtime python scripts/extract_terms.py \
    --inputs "$EXTRACT_INPUT" \
    --out "$OUT_DIR/terms.txt" \
    --min-count "$MIN_COUNT" \
    --max-terms "$MAX_TERMS"

echo ""
echo "=== 完了 ==="
echo "用語リスト: $OUT_DIR/terms.txt"
echo "先頭 20 行:"
head -n 20 "$OUT_DIR/terms.txt"
